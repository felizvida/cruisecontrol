{
  "$schema": "https://opencode.ai/config.json",

  "experimental": {
    "mcp_timeout": 600000
  },

  // Enable only the servers you actually use.
  "mcp": {
    "codex": {
      "type": "local",
      "enabled": true,
      "command": ["/bin/bash", "/Users/liux17/codex/autoresearch/scripts/codex-mcp-local.sh"]
    },
    "zotero": {
      "type": "local",
      "enabled": false,
      "command": ["zotero-mcp"]
    },
    "obsidian-vault": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@bitbonsai/mcpvault", "/path/to/your/vault"]
    }
  }
}
