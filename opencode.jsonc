{
  "$schema": "https://opencode.ai/config.json",

  // This file configures the pure OpenCode route only.
  // The repo-default pure Codex route does not depend on this file.
  // Pin both the main and small model on this machine so OpenCode
  // stays fully native and does not fall back to an unavailable default.
  "model": "amazon-bedrock/amazon.nova-premier-v1:0",
  "small_model": "amazon-bedrock/amazon.nova-premier-v1:0",

  // Optional MCP integrations. The core workflow does not require any MCP server.
  "mcp": {
    "zotero": {
      "type": "local",
      "enabled": false,
      "command": ["zotero-mcp"]
    },
    "obsidian-vault": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@bitbonsai/mcpvault", "/path/to/your/vault"]
    }
  }
}
